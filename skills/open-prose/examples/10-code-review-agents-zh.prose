# 使用代理的代码审查工作流
# 此示例展示如何使用代理进行多步骤代码审查流程。

# 定义具有特定角色的代理
agent security-reviewer:
  model: opus
  prompt: "你是一名专注于识别漏洞的安全专家"

agent performance-reviewer:
  model: sonnet
  prompt: "你是一名性能优化专家"

agent style-reviewer:
  model: haiku
  prompt: "你检查代码风格和最佳实践"

# 步骤 1：快速风格检查（快速）
# 备注：使用轻量级模型进行快速检查，适合代码风格和命名规范等表面问题
session: style-reviewer
  prompt: "审查 src/ 目录中的代码，检查风格问题和命名规范"

# 步骤 2：性能分析（中等）
# 备注：使用中型模型分析性能瓶颈，关注算法复杂度和资源使用
session: performance-reviewer
  prompt: "识别任何性能瓶颈或优化机会"

# 步骤 3：安全审计（彻底）
# 备注：使用最强大的模型进行深入安全审查，重点关注 OWASP Top 10 漏洞
session: security-reviewer
  prompt: "执行安全审查，查找 OWASP Top 10 漏洞"

# 步骤 4：总结报告
# 备注：使用中型模型创建综合报告，将各个审查结果整合并设置优先级
session: security-reviewer
  model: sonnet
  prompt: "创建所有审查结果的综合报告，包含优先级排名"
