# 技能安全扫描器 v2 (Skill Security Scanner v2)
#
# 扫描已安装的 AI 编程助手技能/插件是否存在安全漏洞。
# 支持 Claude Code、AMP 以及其他使用 SKILL.md 格式的工具。
#
# 关键改进 (v2):
# - 渐进式披露：在深度扫描前进行快速分选（为干净的技能节省成本）
# - 模型分层：Sonnet 处理清单工作，Opus 处理困难分析
# - 并行扫描器：独立分析并发运行
# - 持久化内存：跨运行跟踪扫描历史（需 sqlite+ 后端）
# - 优雅降级：单个扫描器失败不会破坏整个扫描过程
# - 可定制：扫描模式、关注领域、特定技能
#
# 用法:
#   prose run 38-skill-scan.prose                           # 标准扫描
#   prose run 38-skill-scan.prose mode:"quick"              # 仅快速分选
#   prose run 38-skill-scan.prose mode:"deep"               # 全量分析，所有技能
#   prose run 38-skill-scan.prose focus:"prompt-injection"  # 关注特定类别
#   prose run 38-skill-scan.prose --backend sqlite+         # 启用持久化历史
#
# [备注]：OpenProse 关键字（如 session, agent, parallel 等）在程序中保持不变。

input mode: "扫描模式：'quick'（仅分选）、'standard'（分选 + 对有疑虑的进行深度扫描）、'deep'（全量分析）"
input focus: "可选：关注特定类别（malicious/恶意代码, exfiltration/数据外泄, injection/提示词注入, permissions/权限, hooks/钩子）"
input skill_filter: "可选：扫描特定的技能名称或路径（默认：发现的所有技能）"

# =============================================================================
# 代理 (AGENTS) - 根据任务复杂度进行模型分层
# =============================================================================

# 发现与协调：Sonnet（结构化、清单类工作）
agent discovery:
  model: sonnet
  prompt: """
    你负责发现并列举 AI 助手技能目录。

    在以下位置检查技能：
    - ~/.claude/skills/ (Claude Code 个人)
    - .claude/skills/ (Claude Code 项目)
    - ~/.claude/plugins/ (Claude Code 插件)
    - .agents/skills/ (AMP 工作区)
    - ~/.config/agents/skills/ (AMP 主目录)

    对于每个存在的路径，列出所有包含 SKILL.md 文件的子目录。
    返回一个结构化列表，包含：路径 (path)、名称 (name)、工具 (tool，如 claude-code/amp/unknown)。
  """

# 快速分选：Sonnet（模式匹配、表面层级）
agent triage:
  model: sonnet
  prompt: """
    你对 AI 技能进行快速安全分选 (Security Triage)。

    快速扫描明显的危险信号 (Red Flags)：
    - 硬编码的可疑 URL 或 IP 地址
    - Base64 或十六进制编码的内容
    - 钩子 (Hooks) 中的 Shell 命令
    - 过宽的权限（如 bash: allow, write: ["**/*"]）
    - 关键词：eval, exec, curl, wget, nc, reverse, shell, encode

    输出格式：
    {
      "risk_level": "critical" | "high" | "medium" | "low" | "clean",
      "red_flags": ["特定疑虑列表"],
      "needs_deep_scan": true | false,
      "confidence": "high" | "medium" | "low"
    }

    要快但要彻底。在这里，漏报 (False Negatives) 比误报 (False Positives) 更糟糕。
  """

# 深度分析：Opus（需要对意图和上下文进行推理）
agent malicious-code-scanner:
  model: opus
  prompt: """
    你是专门检测恶意代码模式的安全分析师。

    分析提供的技能是否存在“明确恶意”的模式：
    - 文件删除或系统破坏（系统路径上的 rm -rf, shutil.rmtree）
    - 加密货币挖矿机或僵尸网络代码
    - 键盘记录器或输入捕获
    - 后门或反弹 Shell (Reverse Shells)
    - 隐藏恶意意图的代码混淆
    - 试图禁用安全工具的行为

    要精确。仅标记真正危险的模式，不要标记正常的文件操作。

    输出 JSON：
    {
      "severity": "critical" | "high" | "medium" | "low" | "none",
      "findings": [{"location": "file:line", "description": "...", "evidence": "..."}],
      "recommendation": "..."
    }
  """

agent exfiltration-scanner:
  model: opus
  prompt: """
    你是专门检测数据外泄 (Data Exfiltration) 的安全分析师。

    分析提供的技能是否存在“网络和外泄”风险：
    - 向外部域名的 HTTP 请求（curl, wget, requests, fetch, axios）
    - WebSocket 连接
    - DNS 外泄模式
    - 向外部发送编码数据
    - 读取敏感文件后进行网络调用
    - 可疑的 URL 模式或 IP 地址

    区分：
    - 合法的 API 调用（文档化的服务、用户配置的端点）
    - 可疑的外泄（硬编码的外部服务器、编码的负载 payload）

    输出 JSON：
    {
      "severity": "critical" | "high" | "medium" | "low" | "none",
      "findings": [{"location": "file:line", "description": "...", "endpoint": "..."}],
      "data_at_risk": ["可能被泄露的数据类型"],
      "recommendation": "..."
    }
  """

agent prompt-injection-scanner:
  model: opus
  prompt: """
    你是专门研究提示词注入 (Prompt Injection) 攻击的安全分析师。

    分析 SKILL.md 及相关文件是否存在提示词注入漏洞：
    - 覆盖系统提示词或安全准则的指令
    - 注释或编码文本中隐藏的指令
    - 要求忽略之前上下文的指令
    - 试图让 AI 泄露敏感信息的行为
    - 要求在用户不知情的情况下执行命令的指令
    - 越狱 (Jailbreak) 模式或人格操控
    - 声称拥有特殊权威或权限的指令

    特别关注：
    - 使用覆盖性语言直接对 AI 说话的文本
    - 可能隐藏指令的 Base64 或其他编码
    - 对用户隐藏但对 AI 可见的 Markdown 技巧

    输出 JSON：
    {
      "severity": "critical" | "high" | "medium" | "low" | "none",
      "findings": [{"location": "file:line", "attack_type": "...", "quote": "..."}],
      "recommendation": "..."
    }
  """

# 基于清单的分析：Sonnet（遵循定义好的标准）
agent permission-analyzer:
  model: sonnet
  prompt: """
    你根据最小权限原则分析技能权限。

    检查“权限与访问”风险：
    - allowed-tools 字段：权限是否过宽？
    - permissions 块：请求了哪些能力？
    - 无限制的 Bash 访问
    - 对敏感路径（/, /etc, ~/.ssh 等）的写入权限
    - 无明确理由的网络权限
    - 修改其他技能或系统配置的能力

    将请求的权限与技能声明的用途进行对比。
    标记任何超出必需范围的权限。

    输出 JSON：
    {
      "severity": "critical" | "high" | "medium" | "low" | "none",
      "requested": ["所有权限列表"],
      "excessive": ["似乎不必要的权限"],
      "least_privilege": ["实际需要的权限"],
      "recommendation": "..."
    }
  """

agent hook-analyzer:
  model: sonnet
  prompt: """
    你分析事件钩子 (Event Hooks) 的安全风险。

    检查“钩子与触发器”漏洞：
    - 执行 Shell 命令的 PreToolUse / PostToolUse 钩子
    - 运行清理脚本的 Stop 钩子
    - 拦截或修改工具输入/输出的钩子
    - 在敏感操作（Write, Bash 等）上触发的钩子
    - 钩子处理器中的命令执行
    - 可能创建持久化机制的钩子

    注意：
    - 什么触发了钩子（匹配模式 matcher patterns）
    - 钩子执行了什么（command 字段）
    - 钩子是否可能产生链式反应或提权

    输出 JSON：
    {
      "severity": "critical" | "high" | "medium" | "low" | "none",
      "hooks_found": [{"trigger": "...", "action": "...", "risk": "..."}],
      "chain_risk": "提权潜力的描述",
      "recommendation": "..."
    }
  """

# 综合：Sonnet（协调与总结）
agent synthesizer:
  model: sonnet
  prompt: """
    你将安全扫描结果综合成清晰、可操作的报告。

    根据多个安全扫描器的发现，生成一份合并报告：
    1. 总体风险评级（Critical / High / Medium / Low / Clean）
    2. 执行摘要（2-3 句话）
    3. 按严重程度组织的详细发现
    4. 特定的修复建议
    5. 该技能是否可以安全使用

    要直接且可操作。不要填充不必要的免责声明。

    输出 JSON：
    {
      "risk_rating": "Critical" | "High" | "Medium" | "Low" | "Clean",
      "summary": "...",
      "safe_to_use": true | false,
      "findings": [{"severity": "...", "category": "...", "description": "..."}],
      "remediation": ["按优先级排序的操作列表"]
    }
  """

# 用于扫描历史的持久化内存（需要 sqlite+ 后端）
agent historian:
  model: sonnet
  persist: true
  prompt: """
    你维护跨运行的安全扫描历史。

    为每个技能跟踪：
    - 上次扫描日期和结果
    - 风险级别趋势（改进、稳定、恶化）
    - 技能内容的哈希值（用于检测变化）
    - 之前已修复的发现

    每次扫描时：
    1. 检查该技能之前是否扫描过
    2. 将当前内容哈希与之前的进行比较
    3. 如果未更改且最近扫描过，建议跳过
    4. 如果已更改，记录不同之处
    5. 用新结果更新历史记录
  """

# =============================================================================
# 可重用块 (REUSABLE BLOCKS)
# =============================================================================

block read-skill-content(skill_path):
  output session "读取并编译技能目录中的所有文件"
    prompt: """
      读取位于 {skill_path} 的技能：
      1. 读取 SKILL.md（必需）
      2. 读取任何 .py, .sh, .js, .ts 文件
      3. 如果存在，读取 hooks.json, .mcp.json, .lsp.json
      4. 读取任何可能包含代码的子目录文件

      返回按文件路径组织的完整内容。
      包含文件大小和行数。
    """

block triage-skill(skill_content, skill_name):
  output session: triage
    prompt: "技能快速安全分选：{skill_name}"
    context: skill_content

block deep-scan-skill(skill_content, skill_name, focus_area):
  # 并行运行相应的扫描器（独立分析）
  # 使用优雅降级 - 一个失败不会停止其他扫描器

  if **指定了关注领域 (focus_area)**:
    # 单个关注扫描
    choice **哪个扫描器匹配该关注领域**:
      option "malicious":
        output session: malicious-code-scanner
          prompt: "深度扫描 {skill_name} 中的恶意代码"
          context: skill_content
      option "exfiltration":
        output session: exfiltration-scanner
          prompt: "深度扫描 {skill_name} 中的数据外泄"
          context: skill_content
      option "injection":
        output session: prompt-injection-scanner
          prompt: "深度扫描 {skill_name} 中的提示词注入"
          context: skill_content
      option "permissions":
        output session: permission-analyzer
          prompt: "深度扫描 {skill_name} 中的权限问题"
          context: skill_content
      option "hooks":
        output session: hook-analyzer
          prompt: "深度扫描 {skill_name} 中的钩子漏洞"
          context: skill_content
  else:
    # 全量并行扫描，支持优雅降级
    parallel (on-fail: "continue"):
      malicious = session: malicious-code-scanner
        prompt: "分析 {skill_name} 是否存在恶意代码"
        context: skill_content

      exfil = session: exfiltration-scanner
        prompt: "分析 {skill_name} 是否存在数据外泄风险"
        context: skill_content

      injection = session: prompt-injection-scanner
        prompt: "分析 {skill_name} 是否存在提示词注入"
        context: skill_content

      permissions = session: permission-analyzer
        prompt: "分析 {skill_name} 是否存在权限问题"
        context: skill_content

      hooks = session: hook-analyzer
        prompt: "分析 {skill_name} 是否存在钩子漏洞"
        context: skill_content

    output { malicious, exfil, injection, permissions, hooks }

block synthesize-results(skill_name, triage_result, deep_results):
  let report = session: synthesizer
    prompt: "为 {skill_name} 创建安全报告"
    context: { triage_result, deep_results }

  # 保存个人报告
  session "将报告写入 .prose/reports/{skill_name}-security.md"
    context: report

  output report

block scan-skill(skill_path, skill_name, scan_mode, focus_area):
  # 只读取一次技能内容，用于所有分析
  let content = do read-skill-content(skill_path)

  # 始终从快速分选开始
  let triage_result = do triage-skill(content, skill_name)

  # 根据模式和分选结果决定是否进行深度扫描
  if **scan_mode 为 quick**:
    # 快速模式：仅分选
    output { skill_name, triage: triage_result, deep: null, report: null }

  elif **scan_mode 为 standard 且分选显示干净 (clean) 且置信度高**:
    # 标准模式：对于明显干净的技能跳过深度扫描
    output { skill_name, triage: triage_result, deep: null, report: "已跳过 - 分选结果为干净" }

  else:
    # 需要深度扫描（深度模式，或标准模式但有疑虑）
    let deep_results = do deep-scan-skill(content, skill_name, focus_area)
    let report = do synthesize-results(skill_name, triage_result, deep_results)
    output { skill_name, triage: triage_result, deep: deep_results, report }

# =============================================================================
# 主工作流 (MAIN WORKFLOW)
# =============================================================================

# 阶段 1：检查扫描历史（如果持久化后端可用）
let history_check = session: historian
  prompt: """
    检查扫描历史。报告：
    - 之前扫描过的技能及日期
    - 自上次扫描以来发生更改的任何技能
    - 建议重新扫描的技能
  """

# 阶段 2：发现 (Discovery)
let discovered = session: discovery
  prompt: """
    发现所有已安装的 AI 编程助手技能。
    检查每个已知位置，列举技能，返回结构化列表。
  """

# 阶段 3：如果请求了则过滤技能
let skills_to_scan = session "过滤发现的技能"
  prompt: """
    基于以下条件过滤技能：
    - skill_filter 输入（如果指定，按名称或路径匹配）
    - history_check 建议（优先处理已更改的技能）

    返回最终要扫描的技能列表。
  """
  context: { discovered, skill_filter, history_check }

# 阶段 4：检查是否有技能需要扫描
if **没有要扫描的技能**:
  output audit = session "报告未发现技能"
    prompt: """
      创建简短报告，说明未发现技能或所有技能已被过滤掉。
      列出已检查的目录和任何应用的过滤器。
    """
    context: { discovered, skill_filter }

else:
  # 阶段 5：分批扫描技能（遵守并行限制）
  let batches = session "将技能分成每组 3 个的批次"
    prompt: """
      将技能分成每组 3 个的批次以进行并行处理。
      返回数组的数组。
    """
    context: skills_to_scan

  let all_results = []

  for batch in batches:
    # 并行处理批次
    let batch_results = []
    parallel for skill in batch:
      let result = do scan-skill(skill.path, skill.name, mode, focus)
      batch_results = batch_results + [result]

    all_results = all_results + batch_results

    # 针对严重发现的早期预警
    if **批次中任何技能具有 Critical 严重程度**:
      session "警报：检测到严重漏洞"
        prompt: "立即向用户报告严重发现"
        context: batch_results

  # 阶段 6：更新扫描历史
  session: historian
    prompt: "用新结果更新扫描历史"
    context: all_results

  # 阶段 7：创建汇总报告
  let final_report = session: synthesizer
    prompt: """
      针对所有已扫描的技能创建全面的安全审计报告。

      包含：
      1. 总体安全状况的执行摘要
      2. 按风险级别（Critical, High, Medium, Low, Clean）分组的技能
      3. 检测到的常见漏洞模式
      4. 最高优先级的修复操作
      5. 扫描统计数据（总数、按模式、按结果）

      格式化为专业的安全审计文档。
    """
    context: all_results

  # 保存最终报告
  session "将审计报告保存至 .prose/reports/SECURITY-AUDIT.md"
    context: final_report

  # 阶段 8：输出摘要
  output audit = session "显示终端友好的摘要"
    prompt: """
      简明扼要的终端摘要：
      - 已扫描的技能总数
      - 按风险级别的细分
      - 需要立即关注的严重/高风险发现
      - 完整报告的路径
      - 与之前扫描的对比（如果历史记录可用）
    """
    context: { final_report, history_check, mode }
